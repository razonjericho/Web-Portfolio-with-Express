<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Contact | Jericho Pete Razon</title>
    <link rel="stylesheet" href="/styles/global.css" />
    <link rel="stylesheet" href="/styles/contact.css" />
  </head>

  <body>
    <%- include('partials/header') %>
    <main>
      <section class="contact-page">
        <div class="contact-content">
          <div class="contact-text">
            <h1>Contact Me</h1>
            <p>
              Feel free to reach out! I'd be happy to discuss potential projects, collaboration opportunities, or full-stack development
              roles. I'm always eager to apply my skills in real-world environments while continuing to grow and refine my expertise.
            </p>

            <p>I look forward to connecting with you.</p>
          </div>

          <div class="contact-input">
            <form action="/contact" method="POST">
              <div class="name-row">
                <div class="form-group">
                  <input type="text" id="fName" name="fName" placeholder="" required />
                  <label for="fName">First Name </label>
                </div>
                <div class="form-group">
                  <input type="text" id="lName" name="lName" placeholder="" required />
                  <label for="lName">Last Name </label>
                </div>
              </div>

              <div class="form-group">
                <input type="email" id="email" name="email" placeholder="" required />
                <label for="email" class="email-label">Email </label>
              </div>
              <div class="form-group">
                <textarea id="message" name="message" placeholder="" required></textarea>
                <label for="message" class="message-label">Message </label>
              </div>
              <button class="btn" type="submit">Send</button>
            </form>
          </div>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
    <script src="/js/hamburger.js"></script>
  </body>
</html>
